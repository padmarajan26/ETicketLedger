      "get": {
        "tags": [
          "ETicketLedger.API"
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/api/Ledger/entries": {
      "get": {
        "tags": [
          "Ledger"
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
